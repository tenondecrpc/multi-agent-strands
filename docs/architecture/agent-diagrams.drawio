        <mxCell id="invocation-flow" value="HTTP POST /tickets/{id}/process&#xa;  → Celery: process_ticket_task(ticket_id)&#xa;    → pipeline.launch_agent_pipeline(ticket_id)&#xa;      → create_orchestrator_agent(ticket_id, session_id)&#xa;        → agent.stream_async(&quot;Process Jira ticket {ticket_id}...&quot;)&#xa;          → async for event in agent.stream_async(prompt):&#xa;              Track tool calls, emit events, update progress" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=11;fontFamily=monospace" vertex="1" parent="1">
          <mxGeometry x="60" y="710" width="600" height="100" as="geometry" />
        </mxCell>

        <mxCell id="event-emission" value="Event Emission (per tool call)&#xa;  → agent_state_change (working/success/error)&#xa;  → agent_log (tool call/result messages)&#xa;  → ProgressTracker (every 2s while sub-agent runs)&#xa;  → Socket.IO → Frontend (real-time updates)" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=11;fontFamily=monospace" vertex="1" parent="1">
          <mxGeometry x="700" y="710" width="600" height="100" as="geometry" />
        </mxCell>

