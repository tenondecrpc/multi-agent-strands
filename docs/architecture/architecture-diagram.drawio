        <mxCell id="arrow8" value="Publish" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#9900CC;fontSize=10;" edge="1" parent="1" source="agents-box" target="eventbus">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        
        <!-- Backend to Database -->
        <mxCell id="arrow9" value="SQLAlchemy ORM" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#006600;fontSize=10;" edge="1" parent="1" source="services-box" target="sqlalchemy">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        
        <!-- SQLAlchemy to PostgreSQL -->
        <mxCell id="arrow10" value="asyncpg" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#006600;fontSize=10;" edge="1" parent="1" source="sqlalchemy" target="postgres">
          <mxGeometry relative="1" as="geometry" />
